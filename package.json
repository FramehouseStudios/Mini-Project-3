{
  "name": "blockbuster-plus",
  "version": "3.0.0",
  "description": "A full-stack MVC film discovery and rental-planning application",
  "main": "server.js",
  "type": "commonjs",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "prestart": "npm run build:web",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:web": "npm run dev --workspace @blockbuster-plus/web",
    "build": "npm run build:web",
    "build:web": "npm run build --workspace @blockbuster-plus/web",
    "seed": "node scripts/seed-database.js",
    "pretest": "npm run build:web",
    "test": "NODE_ENV=test node --test test/*.test.js",
    "check": "npm run lint && npm run lint:web && npm run test && npm run validate:data",
    "lint:web": "npm run lint --workspace @blockbuster-plus/web",
    "lint": "eslint . --max-warnings 0",
    "validate:data": "node scripts/validate-films.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "author": "Joshua Ojeda",
  "license": "ISC",
  "dependencies": {
    "express": "^5.1.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0"
  }
}
